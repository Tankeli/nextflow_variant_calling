/*
 * DDE_33 — single-cell variant-calling pipeline
 * Numbat (CNV) + CopyKAT (aneuploidy) + souporcell (SNV) for paired Dx/Rel paediatric AML.
 * See CLAUDE.md for architecture and scratchpad.md for the build plan.
 */

nextflow.enable.strict = false

plugins {
    id 'nf-schema@2.7.2'
    id 'nf-prov@1.7.0'
    id 'nf-co2footprint@1.2.1'
}

// ── Parameters (defaults; override via -params-file or the Seqera launch form) ──
params {
    // Input / output
    input  = null
    outdir = 'results'

    // Caller toggles
    run_numbat     = true
    run_copykat    = true
    run_souporcell = true
    run_clonetracer = true   // downstream Bayesian clonal integration (Numbat CNV + souporcell SNV + mtDNA)

    // Integration (Phase 2): per-patient master table + headline clonal-tracing Sankeys.
    // Off by default (uninformative on healthy controls); needs all callers + reference mapping.
    run_integration = false

    // CopyKAT robustness/reliability analysis (separate track, off by default). Fans out CopyKAT
    // over a parameter x seed grid (subworkflow) so the standalone Python can measure where the
    // aneuploid/diploid boundary lies and how stable the per-cell call is. Requires run_copykat;
    // the use_norm_ref=true arm additionally requires run_reference_mapping.
    run_copykat_robustness         = false
    copykat_robustness_ks_cut      = [0.05, 0.1, 0.15, 0.2]   // segmentation/classification stringency
    copykat_robustness_win_size    = [25]                     // segmentation window (genes)
    copykat_robustness_ngene_chr   = [5]                      // min genes per chromosome
    copykat_robustness_distance    = ['euclidean']            // add 'spearman'/'pearson' to widen
    copykat_robustness_use_norm_ref = [false]                 // [true,false] to test a known-normal baseline
    copykat_robustness_seeds       = [1, 2, 3, 4, 5]          // seed replicates (per-cell stability)
    copykat_norm_celltypes         = ['T', 'NK', 'CTL']       // ref_cell_type labels used as diploid baseline

    // Annotation branch (parallel to callers; does not gate them)
    run_qc                = true
    run_reference_mapping = true
    qc_min_genes              = 200
    qc_min_umi                = 500
    qc_max_mito_pct           = 20
    qc_expected_doublet_rate  = 0.06
    // No default — set explicitly per run (see params.yaml / params-*.yaml). A relative
    // ../DDE_32_... default silently bound to one user's sibling-directory layout and failed
    // confusingly at checkIfExists on a fresh checkout; null + the guard in workflows/
    // variantcalling.nf gives a clear "set refmap_atlas" error instead.
    refmap_atlas              = null
    // Frozen atlas UMAP (cell, UMAP_1, UMAP_2[, celltype]) = the shared "reference-map space"
    // every sample is projected into. Null -> compute per-run (not cross-sample stable).
    refmap_umap               = null
    refmap_celltype_key       = 'cell_type'
    refmap_confidence_threshold = 0.5
    refmap_n_pcs              = 30
    // Souporcell K used for the per-patient clone overlay figure.
    souporcell_plot_k         = 3
    scanpy_container          = 'scanpy-scrublet:1.11'  // build from containers/scanpy/Dockerfile

    // ── RNA downstream best-practices stack (ported from DDE_27; parallel to the callers) ──
    // All OFF by default — additive analysis track, enable per run via a -params-file.
    // Standalone DOWNSTREAM entry input (sample,patient,timepoint,matrix CSV); off existing matrices.
    downstream_samplesheet = null
    // Standalone SOUPORCELL_ONLY entry input (sample,patient,timepoint,outs CSV); off published outs.
    souporcell_samplesheet = null
    run_rna_core        = false  // QC -> norm -> feature select -> dimred -> cluster -> annotate (per sample)
    run_rna_integration = false  // multi-sample cohort integration (scVI/scANVI/BBKNN + scib) [needs run_rna_core]
    run_pseudotime      = false  // diffusion pseudotime (per sample)                            [needs run_rna_core]
    run_velocity        = false  // RNA velocity (per sample; needs a velocyto loom)             [needs run_rna_core]
    run_de              = false  // differential expression (per patient, Dx vs Rel)            [needs run_rna_core]
    run_composition     = false  // compositional analysis (cohort, on integrated)  [needs run_rna_integration]
    run_protein         = false  // surface-protein / ADT branch (CITE-seq samples only)
    // RNA QC (notebook 01) — renamed from DDE_27's qc_* to avoid clashing with the SCANPY_QC
    // params above. SoupX is not wired (no per-sample raw matrix from `cellranger multi`).
    rna_qc_nmads_counts   = 5      // MADs for log1p_total_counts / n_genes / pct_top_20 outliers
    rna_qc_nmads_mt       = 3      // MADs for pct_counts_mt outliers
    rna_qc_max_mito_pct   = 8      // hard mito ceiling (%)
    rna_qc_min_cells      = 20     // drop genes expressed in < N cells
    run_soupx             = false  // SoupX ambient-RNA correction; uses CELLRANGER.out.raw (the
                                   // per-sample raw matrix). Enabling it changes the CELLRANGER_MULTI
                                   // task hash, so the next -resume re-runs Cell Ranger once.
    run_scdblfinder       = true   // doublet scoring (annotate only; not removed)
    // RNA normalization (02) / feature selection (03) / dimred (04) / clustering (05)
    n_top_genes           = 4000   // deviance-based HVG count
    n_pcs                 = 50
    n_neighbors           = 15
    leiden_resolutions    = '0.25,0.5,1.0'   // comma-separated; split in the module
    leiden_key_resolution = 1.0              // resolution used downstream for annotation
    // RNA annotation (06)
    celltypist_model      = 'Immune_All_Low.pkl'
    // RNA integration (07)
    integration_methods   = 'scvi,scanvi,bbknn'   // subset of scvi,scanvi,bbknn
    integration_batch_key = 'batch'               // .obs['batch'] from the optional samplesheet
                                                   // 'batch' column; rna_qc.py falls back to the
                                                   // per-sample id when that column is omitted
    // RNA DE (10)
    de_method             = 'wilcoxon'  // wilcoxon (robust for 1-Dx/1-Rel) | mast | edger | pertpy
    de_groupby            = 'cell_type'
    // RNA velocity (09): dir of <sample>.loom files (velocyto output); null disables velocity
    velocity_loom_dir     = null
    // Protein / ADT (12-17)
    prot_norm_method      = 'clr'    // dsb | clr
    prot_leiden_resolution = 1.0
    // Containers for the RNA downstream stack (build from containers/<stage>/Dockerfile or reuse
    // DDE_27's built .sif on Viking — see conf/viking.config).
    rna_preprocessing_container = 'dde27-rna-preprocessing:0.1'  // QC / normalize / feature-select
    rna_clustering_container    = 'dde27-rna-clustering:0.1'     // dimred / cluster
    rna_annotation_container    = 'dde27-rna-annotation:0.1'
    rna_integration_container   = 'dde27-rna-integration:0.1'
    rna_pseudotime_container    = 'dde27-rna-pseudotime:0.1'
    rna_velocity_container      = 'dde27-rna-velocity:0.1'
    rna_de_container            = 'dde27-rna-de:0.1'
    composition_container       = 'dde27-composition:0.1'
    protein_container           = 'dde27-protein:0.1'

    // ── Bulk proteomics branch (ported from DDE_31; R -> Python, DESP kept as one R step) ──
    // Optional, default OFF. Starts from a Spectronaut search matrix (NOT FASTQ): runs as a gated
    // branch in the main workflow and as a standalone `-entry PROTEOMICS`. PREP+BATCH are the spine.
    run_proteomics        = false
    prot_run_de           = true   // limma DE + volcano                                  [spine + DE]
    prot_run_viz          = true   // heatmaps / PCA / UMAP
    prot_run_stage4       = true   // sig-protein HM/PCA/kmeans/pseudotime/boxplots/offset [needs prot_run_de]
    prot_run_ml           = true   // decision tree + random forest
    prot_run_desp         = false  // DESP cell-state demix (R) + viz   [needs proportions + prot_run_de]
    // Inputs (files; required when run_proteomics / -entry PROTEOMICS)
    proteomics_norm        = null  // normalized Spectronaut protein matrix (features x samples)
    proteomics_nonnorm     = null  // un-normalized matrix (falls back to norm if omitted)
    proteomics_design      = null  // design TSV: sample, condition, replicate(=patient), Batch
    proteomics_contaminants = null // contaminant ID list (one per line)
    proteomics_config      = null  // experiment YAML, deep-merged over assets/proteomics_default.yaml
    // DESP proportions: external TSV, OR derived from this run's scRNA reference-mapping celltypes
    proteomics_proportions = null  // cell_type x sample TSV (skips scRNA-derived proportions)
    proteomics_celltypes_glob = null // glob of <sample>_celltypes.csv (standalone entry only)
    proteomics_sample_map  = null  // TSV rna_sample<TAB>prot_sample to align scRNA->proteomics ids
    // Behaviour (mirror the YAML where relevant)
    prot_batch_method      = 'both'        // none|limma|combat|both (must match config batch method)
    prot_desp_bulk_source  = 'limma'       // limma|combat|raw — which matrix feeds DESP/VIZ/STAGE4/ML
    prot_desp_per_patient  = true
    prot_condition_col     = 'condition'
    prot_replicate_col     = 'replicate'
    prot_id_col            = 'Protein.Ids'
    prot_celltype_col      = 'ref_cell_type'  // column in <sample>_celltypes.csv (REFERENCE_MAPPING)
    // Containers: Python stack (most stages) + an R image carrying the DESP package
    proteomics_container   = 'dde31-proteomics:0.1'   // pandas/scipy/sklearn/scanpy/seaborn/inmoose
    proteomics_r_container = 'dde31-desp:0.1'          // R + DESP + optparse

    // References (one-time prep — see bin/setup_numbat.sh)
    cellranger_index = null
    fb_reference     = null
    cellranger_container = 'nf-core/cellranger:8.0.0'  // licensed; build/pull locally (not on biocontainers)
    numbat_snpvcf    = '/data/genome1K.phase3.SNP_AF5e2.chr1toX.hg38.vcf'  // in-container path
    numbat_paneldir  = '/data/1000G_hg38'                                  // in-container path
    numbat_gmap      = '/Eagle_v2.4.1/tables/genetic_map_hg38_withX.txt.gz'// in-container path
    numbat_container = 'docker.io/pkharchenkolab/numbat-rbase:latest'
    souporcell_fasta = null
    souporcell_container = 'docker.io/cumulusprod/souporcell:2.5'
    samtools_container   = 'quay.io/biocontainers/samtools:1.21--h50ea8bc_0'
    copykat_container    = 'copykat:1.1.0'  // build from containers/copykat/Dockerfile

    // Caller options
    numbat_joint       = true          // pool Dx+Rel per patient (cross-timepoint comparable clone IDs)
    numbat_max_entropy = 0.8           // relaxed; per-sample defaults (0.5) fail on this cohort
    numbat_min_llr     = 5             // operating point from the seed x min_LLR sweep (analysis 04):
                                       //   3 keeps low-LLR noise (e.g. PBM_2 LLR 4.6); 5 drops it while
                                       //   retaining every real joint clone (PBMMC_3 + both tumours);
                                       //   10 over-prunes (loses Patient_2). Pair with a seed-ARI gate
                                       //   (>=3 seeds, flag mean clone ARI < ~0.9) for full robustness.
    souporcell_k       = '2,3,5,12'    // K sweep (comma-separated; split in the workflow)

    // CloneTracer (veltenlab) — downstream clonal integration
    clonetracer_container        = 'clonetracer:1.0'   // build from containers/clonetracer/Dockerfile
    clonetracer_k                = 3                    // which souporcell K's genotypes feed the SNV axis
    clonetracer_iterations       = 0                    // SVI iters; 0 = auto (300 SNV-only / 500 with CNVs). If set, use >=100 (run_clonetracer uses init=iters-100)
    clonetracer_gpu              = false                // -g; recommended but needs a GPU partition
    clonetracer_pseudobulk       = false               // synth per-timepoint bulk_M/N -> enables -s multi-sample model (no exome data here)
    clonetracer_gtf              = 'references/refdata-gex-GRCh38-2024-A/genes/genes.gtf'  // gene->arm map for CNV counts
    clonetracer_max_snvs         = 6                    // cap nuclear-SNV sites taken from souporcell
    clonetracer_max_total_muts   = 6                    // HARD total-mutation cap (priority CNV>SNV>mtDNA); CloneTracer's tree search explodes super-exponentially, keep ~3-6 (0=off)
    // mtDNA pileup (feeds the CloneTracer mtDNA axis; mgatk stays the opt-in alternative)
    clonetracer_mtdna_method     = 'cellsnp'           // 'cellsnp' (default) | 'mgatk'
    clonetracer_mtdna_chrom      = ''                  // mito contig; '' = auto-detect from BAM, fallback chrM
    clonetracer_mtdna_min_maf    = 0.01                // cellsnp-lite --minMAF
    clonetracer_mtdna_min_count  = 20                  // cellsnp-lite --minCOUNT
    clonetracer_mtdna_min_cells  = 10                  // keep mtDNA sites covered in >= N cells
    clonetracer_mtdna_max_sites  = 6                   // cap mtDNA sites (also bounded by clonetracer_max_total_muts)

    // Seqera Platform
    tower_enabled = false

    // Boilerplate
    // 'link' (hardlink) keeps published results as real files that survive a `work/` cleanup,
    // with no extra disk use (work/ and results/ share the scratch Lustre filesystem). Use
    // 'copy' instead if results must live on a different filesystem from work/.
    publish_dir_mode           = 'link'
    validate_params            = true
    monochrome_logs            = false
}

// ── Provenance / carbon reporting (nf-prov + nf-co2footprint) ──
// Reference params.outdir directly (not an early-captured copy) so paths follow profile/CLI
// overrides; otherwise reports leak to the default 'results/' (or the plugin's cwd defaults).
def timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')

prov {
    formats {
        bco {
            file = "${params.outdir}/pipeline_info/nfprov_bco_${timestamp}.json"
            overwrite = true
        }
    }
}

// nf-co2footprint 1.2.x uses nested report/summary/trace blocks (NOT the old flat
// reportFile/traceFile/summaryFile keys, which are silently ignored -> cwd defaults).
co2footprint {
    report  { file = "${params.outdir}/pipeline_info/co2_emissions/co2footprint_report_${timestamp}.html";  overwrite = true }
    summary { file = "${params.outdir}/pipeline_info/co2_emissions/co2footprint_summary_${timestamp}.txt";   overwrite = true }
    trace   { file = "${params.outdir}/pipeline_info/co2_emissions/co2footprint_trace_${timestamp}.txt";     overwrite = true }
    machineType = 'compute cluster'
    ci  = 300.0
    pue = 1.4
}

// ── Base process resources & SLURM executor (ported from DDE_32) ──
includeConfig 'conf/base.config'

executor {
    name             = 'slurm'
    queueSize        = 2000
    submitRateLimit  = '10/1sec'
    exitReadTimeout  = '30 min'
    jobName = {
        task.name
            .replace('[', '(')
            .replace(']', ')')
            .replace(' ', '_')
    }
}

// ── Containers off by default; enabled per profile ──
apptainer   { enabled = false; pullTimeout = '3 hours' }
singularity { enabled = false }
docker      { enabled = false }

profiles {
    apptainer {
        apptainer.enabled    = true
        apptainer.autoMounts = true
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }
    docker {
        docker.enabled = true
    }
    test {
        includeConfig 'conf/test.config'
    }
    viking {
        includeConfig 'conf/viking.config'
    }
    tower {
        params.tower_enabled = true
    }
}

// ── Seqera Platform (Tower) hooks — launch with -with-tower or set tower_enabled ──
// NEVER hardcode the token here. Nextflow reads TOWER_ACCESS_TOKEN (and TOWER_WORKSPACE_ID)
// from the environment automatically; see README for tw-agent setup on Viking.
tower {
    enabled     = params.tower_enabled
    endpoint    = System.getenv('TOWER_API_ENDPOINT') ?: 'https://api.cloud.seqera.io'
    workspaceId = System.getenv('TOWER_WORKSPACE_ID') ?: null
}

// ── Per-process publishDir / args ──
includeConfig 'conf/modules.config'

// ── Execution reports (need enabled=true to render) ──
report   { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/execution_report_${timestamp}.html" }
timeline { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/execution_timeline_${timestamp}.html" }
trace    { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/execution_trace_${timestamp}.txt" }
dag      { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/pipeline_dag_${timestamp}.html" }

manifest {
    name            = 'DDE_33_nextflow_variant_calling'
    author          = 'Daniel Davies'
    description      = 'Single-cell variant calling (Numbat, CopyKAT, souporcell) for paired diagnosis/relapse paediatric AML'
    homePage        = ''
    mainScript      = 'main.nf'
    nextflowVersion = '>=24.04.0'
    version         = '0.1.0'
}
