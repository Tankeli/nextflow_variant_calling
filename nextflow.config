/*
 * DDE_33 — single-cell variant-calling pipeline
 * Numbat (CNV) + CopyKAT (aneuploidy) + souporcell (SNV) for paired Dx/Rel paediatric AML.
 * See CLAUDE.md for architecture and scratchpad.md for the build plan.
 */

nextflow.enable.strict = false

plugins {
    id 'nf-schema@2.7.2'
    id 'nf-prov@1.7.0'
    id 'nf-co2footprint@1.2.1'
}

// ── Parameters (defaults; override via -params-file or the Seqera launch form) ──
params {
    // Input / output
    input  = null
    outdir = 'results'

    // Caller toggles
    run_numbat     = true
    run_copykat    = true
    run_souporcell = true

    // Annotation branch (parallel to callers; does not gate them)
    run_qc                = true
    run_reference_mapping = true
    qc_min_genes              = 200
    qc_min_umi                = 500
    qc_max_mito_pct           = 20
    qc_expected_doublet_rate  = 0.06
    refmap_atlas              = '../DDE_32_paediatric_snv_analysis/references/paediatric_bm_reference/bone_marrow_atlas.h5ad'
    refmap_celltype_key       = 'cell_type'
    refmap_confidence_threshold = 0.5
    refmap_n_pcs              = 30
    scanpy_container          = 'scanpy-scrublet:1.11'  // build from containers/scanpy/Dockerfile

    // References (one-time prep — see bin/setup_numbat.sh)
    cellranger_index = null
    fb_reference     = null
    cellranger_container = 'nf-core/cellranger:8.0.0'  // licensed; build/pull locally (not on biocontainers)
    numbat_snpvcf    = '/data/genome1K.phase3.SNP_AF5e2.chr1toX.hg38.vcf'  // in-container path
    numbat_paneldir  = '/data/1000G_hg38'                                  // in-container path
    numbat_gmap      = '/Eagle_v2.4.1/tables/genetic_map_hg38_withX.txt.gz'// in-container path
    numbat_container = 'docker.io/pkharchenkolab/numbat-rbase:latest'
    souporcell_fasta = null
    souporcell_container = 'docker.io/cumulusprod/souporcell:2.5'
    samtools_container   = 'quay.io/biocontainers/samtools:1.21--h50ea8bc_0'
    copykat_container    = 'copykat:1.1.0'  // build from containers/copykat/Dockerfile

    // Caller options
    numbat_joint       = true          // pool Dx+Rel per patient (cross-timepoint comparable clone IDs)
    numbat_per_sample  = false
    numbat_max_entropy = 0.8           // relaxed; per-sample defaults (0.5) fail on this cohort
    numbat_min_llr     = 3             // relaxed; default 5 fails on this cohort
    souporcell_k       = '2,3,5,12'    // K sweep (comma-separated; split in the workflow)

    // Seqera Platform
    tower_enabled = false

    // Boilerplate
    publish_dir_mode           = 'symlink'
    validate_params            = true
    monochrome_logs            = false
}

// ── Provenance / carbon reporting (nf-prov + nf-co2footprint) ──
// Reference params.outdir directly (not an early-captured copy) so paths follow profile/CLI
// overrides; otherwise reports leak to the default 'results/' (or the plugin's cwd defaults).
def timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')

prov {
    formats {
        bco {
            file = "${params.outdir}/pipeline_info/nfprov_bco_${timestamp}.json"
            overwrite = true
        }
        legacy {
            file = "${params.outdir}/pipeline_info/nfprov_manifest_${timestamp}.json"
            overwrite = true
        }
    }
}

// nf-co2footprint 1.2.x uses nested report/summary/trace blocks (NOT the old flat
// reportFile/traceFile/summaryFile keys, which are silently ignored -> cwd defaults).
co2footprint {
    report  { file = "${params.outdir}/pipeline_info/co2_emissions/co2footprint_report_${timestamp}.html";  overwrite = true }
    summary { file = "${params.outdir}/pipeline_info/co2_emissions/co2footprint_summary_${timestamp}.txt";   overwrite = true }
    trace   { file = "${params.outdir}/pipeline_info/co2_emissions/co2footprint_trace_${timestamp}.txt";     overwrite = true }
    ci  = 300.0
    pue = 1.4
}

// ── Base process resources & SLURM executor (ported from DDE_32) ──
includeConfig 'conf/base.config'

executor {
    name             = 'slurm'
    queueSize        = 2000
    submitRateLimit  = '10/1sec'
    exitReadTimeout  = '30 min'
    jobName = {
        task.name
            .replace('[', '(')
            .replace(']', ')')
            .replace(' ', '_')
    }
}

// ── Containers off by default; enabled per profile ──
apptainer   { enabled = false; pullTimeout = '3 hours' }
singularity { enabled = false }
docker      { enabled = false }

profiles {
    apptainer {
        apptainer.enabled    = true
        apptainer.autoMounts = true
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }
    docker {
        docker.enabled = true
    }
    test {
        includeConfig 'conf/test.config'
    }
    viking {
        includeConfig 'conf/viking.config'
    }
    tower {
        params.tower_enabled = true
    }
}

// ── Seqera Platform (Tower) hooks — launch with -with-tower or set tower_enabled ──
// NEVER hardcode the token here. Nextflow reads TOWER_ACCESS_TOKEN (and TOWER_WORKSPACE_ID)
// from the environment automatically; see README for tw-agent setup on Viking.
tower {
    enabled     = params.tower_enabled
    endpoint    = System.getenv('TOWER_API_ENDPOINT') ?: 'https://api.cloud.seqera.io'
    workspaceId = System.getenv('TOWER_WORKSPACE_ID') ?: null
}

// ── Per-process publishDir / args ──
includeConfig 'conf/modules.config'

// ── Execution reports (need enabled=true to render) ──
report   { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/execution_report_${timestamp}.html" }
timeline { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/execution_timeline_${timestamp}.html" }
trace    { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/execution_trace_${timestamp}.txt" }
dag      { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/pipeline_dag_${timestamp}.html" }

manifest {
    name            = 'DDE_33_nextflow_variant_calling'
    author          = 'Daniel Davies'
    description      = 'Single-cell variant calling (Numbat, CopyKAT, souporcell) for paired diagnosis/relapse paediatric AML'
    homePage        = ''
    mainScript      = 'main.nf'
    nextflowVersion = '>=24.04.0'
    version         = '0.1.0'
}
