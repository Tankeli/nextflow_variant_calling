root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.{json}]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.{nf,config}]
indent_size = 4

# Vendored / generated files — leave formatting untouched
[bin/helper_functions.py]
trim_trailing_whitespace = false
insert_final_newline = false
