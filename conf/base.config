/*
 * Base process resources. Ported from DDE_32 nextflow.config.
 * Resource labels (process_low/medium/high) are attached to modules in conf/modules.config
 * or directly on each process; resourceLimits caps requests to the partition ceiling.
 */

process {
    cpus   = 2
    memory = { 16.GB * task.attempt }
    time   = { 2.h  * task.attempt }

    // Caps requests to the Viking `nodes` partition ceiling (96 cores / ~512 GB / 48 h walltime).
    // NB: a too-low `time` cap silently truncates per-process `time` requests — a 6 h cap here was
    // killing deep CITE-seq CELLRANGER_MULTI (process_high asks 24 h) at exit 140 (SLURM walltime),
    // which aborted the session before Numbat could run for either patient. resourceLimits also
    // clamps the per-attempt escalation below so a 3rd attempt can't request past the ceiling.
    resourceLimits = [ cpus: 32, memory: 512.GB, time: 48.h ]

    // Retry on failure (ported from DDE_32) — kept broad on purpose: Lustre output-visibility lag
    // can surface as a task that "succeeded" but is missing its declared outputs, so we do NOT
    // gate retries on exit code (that would drop the shared-filesystem resilience). Instead, each
    // attempt escalates memory + time via `task.attempt` (capped by resourceLimits), so the
    // genuine OOM (137) / walltime (140) kills the comments above describe get a real second chance
    // instead of re-running identically and burning the retry budget. cpus stay fixed (most tools
    // here are memory/time-bound, not core-bound, and wider core asks just slow scheduling).
    errorStrategy = 'retry'
    maxRetries    = 2
    cache         = 'lenient'
    afterScript   = 'sleep 30'   // tolerate storeDir/output latency on Lustre

    // SLURM account + user env (ignored by the local executor)
    clusterOptions = '--get-user-env --account=biol-stem-2022'

    withLabel: process_low {
        cpus   = 2
        memory = { 16.GB * task.attempt }
        time   = { 2.h  * task.attempt }
    }
    withLabel: process_medium {
        cpus   = 8
        memory = { 64.GB * task.attempt }
        time   = { 12.h * task.attempt }
    }
    withLabel: process_high {
        cpus   = 16
        memory = { 128.GB * task.attempt }
        time   = { 24.h  * task.attempt }
    }
}
