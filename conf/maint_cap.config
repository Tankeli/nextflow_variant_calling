/*
 * One-off walltime cap so every dispatched job finishes before the cluster maintenance
 * reservation (starts ~09:00 the day after launch). process_high defaults to 24h, which the
 * scheduler refuses ("Reserved for maintenance"); cap all labels to 6h so jobs fit the window.
 * Pass via `-c conf/maint_cap.config` for the constrained run; not needed for normal runs.
 * -resume recovers anything not finished before the window.
 */
process {
    resourceLimits = [ cpus: 32, memory: 512.GB, time: 6.h ]
    time = 6.h
    withLabel: process_low    { time = 6.h }
    withLabel: process_medium { time = 6.h }
    withLabel: process_high   { time = 6.h }
    withName: CLONETRACER     { time = 6.h }
}
