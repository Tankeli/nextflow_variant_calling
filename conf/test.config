/*
 * Minimal test profile — validates samplesheet parsing and DAG wiring with the local
 * executor and tiny placeholder inputs. Pair with `-stub` so no tool actually runs:
 *   nextflow run . -profile test -stub
 */

params {
    input  = "${projectDir}/assets/test/samplesheet_test.csv"
    outdir = 'results_test'

    // Dummy reference handles (not read in stub mode)
    cellranger_index = "${projectDir}/assets/test"
    fb_reference     = "${projectDir}/assets/test/feature_reference.csv"
    souporcell_fasta = "${projectDir}/assets/test/genome.fa"
    refmap_atlas     = "${projectDir}/assets/test/atlas.h5ad"

    souporcell_k = '2,3'
}

// Run locally; drop the Lustre sleep so stub tasks finish instantly and cap
// resource requests to what a login/test node actually has.
process {
    executor       = 'local'
    afterScript    = null
    clusterOptions = null
    resourceLimits = [ cpus: 2, memory: 6.GB, time: 1.h ]
}

executor {
    name      = 'local'
    queueSize = 4
}

// Disable provenance / carbon / execution reports for stub validation — they are
// meaningless without real tasks, and their config-block paths resolve params.outdir at
// parse time (before this profile's outdir override), so leaving them on writes to the
// default results/ dir. publishDir is lazy and correctly uses results_test.
prov.enabled = false
co2footprint {
    report  { enabled = false }
    summary { enabled = false }
    trace   { enabled = false }
}
report   { enabled = false }
timeline { enabled = false }
trace    { enabled = false }
dag      { enabled = false }
