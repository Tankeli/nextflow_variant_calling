/*
 * Viking execution profile — run on this cluster with NO container builds, using what's already
 * installed: Lmod modules + existing conda envs + the two local .sif images.
 *   nextflow run . -profile viking -params-file params.yaml -resume
 *
 * Mapping:
 *   CellRanger      -> module CellRanger/9.0.0
 *   samtools (prep) -> module SAMtools
 *   CopyKAT         -> conda env `snv`        (copykat R pkg)
 *   QC + ref map    -> conda env `aml_scrna`  (scanpy + scrublet)
 *   Numbat          -> DDE_32 numbat.sif      (cellsnp-lite + eagle + numbat R + refs baked in)
 *   Souporcell      -> DDE_24 souporcell_release.sif
 *   mtDNA pileup    -> DDE_32 numbat.sif      (cellsnp-lite, default method)
 *   CloneTracer JSON-> conda env `aml_scrna`  (scanpy + pandas + scipy)
 *   CloneTracer run -> conda env `clonetracer` (pyro + pytorch; create from envs/clonetracer.yml
 *                      on the LOGIN node, see README)
 */

params {
    // Numbat + souporcell run from the existing local .sif images (apptainer)
    numbat_container     = '/mnt/scratch/users/hbp534/DDE_32_paediatric_snv_analysis/singularity/numbat.sif'
    souporcell_container = '/mnt/scratch/users/hbp534/DDE_24_CITE_seq_reference_map/singularity/souporcell_release.sif'

    // RNA downstream stack (ported from DDE_27): reuse DDE_27's already-built .sif images rather
    // than rebuilding. Rebuild locally with containers/build_all.sh if these move/disappear.
    rna_preprocessing_container = '/mnt/scratch/users/hbp534/DDE_27_CITE_seq_python_analysis/containers/sif/dde27-rna-preprocessing-0.1.sif'
    rna_clustering_container    = '/mnt/scratch/users/hbp534/DDE_27_CITE_seq_python_analysis/containers/sif/dde27-rna-clustering-0.1.sif'
    rna_annotation_container    = '/mnt/scratch/users/hbp534/DDE_27_CITE_seq_python_analysis/containers/sif/dde27-rna-annotation-0.1.sif'
    rna_integration_container   = '/mnt/scratch/users/hbp534/DDE_27_CITE_seq_python_analysis/containers/sif/dde27-rna-integration-0.1.sif'
    rna_pseudotime_container    = '/mnt/scratch/users/hbp534/DDE_27_CITE_seq_python_analysis/containers/sif/dde27-rna-pseudotime-0.1.sif'
    rna_velocity_container      = '/mnt/scratch/users/hbp534/DDE_27_CITE_seq_python_analysis/containers/sif/dde27-rna-velocity-0.1.sif'
    rna_de_container            = '/mnt/scratch/users/hbp534/DDE_27_CITE_seq_python_analysis/containers/sif/dde27-rna-de-0.1.sif'
    composition_container       = '/mnt/scratch/users/hbp534/DDE_27_CITE_seq_python_analysis/containers/sif/dde27-composition-0.1.sif'
    protein_container           = '/mnt/scratch/users/hbp534/DDE_27_CITE_seq_python_analysis/containers/sif/dde27-protein-0.1.sif'
}

// Apptainer for the .sif-backed processes; conda enabled for the env-activate processes.
apptainer {
    enabled    = true
    autoMounts = true
    pullTimeout = '3 hours'
}

// Nextflow runs apptainer with `--no-home` + `env -` (a clean env), so $HOME inside the container
// is unwritable. Tools that cache to the home dir then fail — notably numba's JIT cache used by
// scanpy (RuntimeError: "cannot cache function ... no locator available"), plus matplotlib/torch.
// Give every task a writable HOME + cache dirs in its own (bind-mounted) work dir. These are
// injected into the container via `eval $(nxf_container_env)` and resolve relative to the task cwd.
// CELLTYPIST_MODEL_DIR lets RNA_ANNOTATE load pre-downloaded models offline (assets/celltypist_models).
env {
    HOME                 = './.home'
    NUMBA_CACHE_DIR      = './.home/numba_cache'
    MPLCONFIGDIR         = './.home/mplconfig'
    XDG_CACHE_HOME       = './.home/cache'
    CELLTYPIST_MODEL_DIR = "${projectDir}/assets/celltypist_models"
}

process {
    // Cell Ranger via module (not a container)
    withName: CELLRANGER_MULTI {
        container    = null
        beforeScript = 'module load CellRanger/9.0.0'
    }

    // souporcell BAM prep + the SOUPORCELL_ONLY ingest both just need samtools + coreutils (module);
    // souporcell itself uses the .sif
    withName: 'SOUPORCELL_PREP|SOUPORCELL_INGEST' {
        container    = null
        beforeScript = 'module load SAMtools/1.15-GCC-11.2.0'
    }

    // CopyKAT (caller + robustness sweep) from the `snv` conda env
    withName: 'COPYKAT|COPYKAT_SWEEP' {
        container    = null
        beforeScript = 'module load Miniconda3/23.5.2-0; source activate snv'
    }

    // scanpy QC + reference mapping + CloneTracer JSON build + all the Python figure/integration
    // steps run from the `aml_scrna` conda env (scanpy + matplotlib + pandas; HEADLINE_FIGURES also
    // needs plotly + kaleido — `pip install plotly kaleido` into aml_scrna on the login node).
    withName: 'SCANPY_QC|REFERENCE_MAPPING|CLONETRACER_BUILD|PLOT_COPYKAT|PLOT_SOUPORCELL|PLOT_CLONETRACER|COHORT_SUMMARY|LSC_SCORING|PHASE0_INTEGRATION|HEADLINE_FIGURES|COPYKAT_NORM_BARCODES' {
        container    = null
        beforeScript = 'module load Miniconda3/23.5.2-0; source activate aml_scrna'
    }

    // CloneTracer pyro model from its own conda env (create on the login node, see README).
    // GPU path (clonetracer_gpu=true): the CUDA env `clonetracer_gpu` (torch 1.13.1+cu117 / pyro
    // 1.8.4) on the `gpu` a40 partition with one GPU. CPU path: the `clonetracer` env, default
    // partition. Both paths use the pinned `clonetracer_gpu` env (pyro 1.8.4 / torch 1.13.1+cu117) —
    // it runs correctly AND quickly on CPU too (the old `clonetracer` env, pyro 1.9.1/torch 2.11, is
    // version-drifted; don't use it). The a40 `gpu` partition is usually ~100% allocated (~16 h queue),
    // and the model is light once mutations are capped (clonetracer_max_total_muts), so CPU is the
    // sensible default. MUST cap OMP/MKL threads to the allocation: with them unset torch spawns ~96
    // OpenMP threads onto 4 cores and DEADLOCKS at the first tensor op (~0 CPU, hangs to walltime).
    withName: CLONETRACER {
        container      = null
        cpus           = 4
        memory         = 32.GB
        // PYTHONNOUSERSITE=1 keeps the job from picking up ~/.local user-site packages (pip leaked
        // torch/numpy there during env setup); the env must be self-contained.
        beforeScript   = { "module load Miniconda3/23.5.2-0; source activate clonetracer_gpu; export PYTHONNOUSERSITE=1; export OMP_NUM_THREADS=${task.cpus}; export MKL_NUM_THREADS=${task.cpus}; export OPENBLAS_NUM_THREADS=${task.cpus}" }
        clusterOptions = params.clonetracer_gpu ?
                           '--get-user-env --account=biol-stem-2022 --partition=gpu --gres=gpu:1' :
                           '--get-user-env --account=biol-stem-2022'
    }

    // NUMBAT_*/SOUPORCELL/MTDNA_PILEUP keep their container = <.sif> (mtDNA uses numbat.sif's
    // cellsnp-lite). Load Apptainer so the engine is on PATH (beforeScript runs outside the
    // container). NOTE: if clonetracer_mtdna_method='mgatk', MTDNA_PILEUP instead needs an mgatk
    // env/container — override this withName then.
    withName: 'NUMBAT_PILEUP|NUMBAT_RUN|SOUPORCELL|MTDNA_PILEUP' {
        beforeScript = 'module load Apptainer/latest'
    }

    // run_numbat() peak RAM scales with cells AND ncores (numbat forks workers, so cores multiply the
    // matrix copies). Measured (analysis 04 sweep): tree-building single-sample joints peak ~100-130 G;
    // a large paired joint (Patient_1, ~15k cells) needs ~400 G. process_high's 128 G first attempt
    // OOMs these, so give NUMBAT_RUN a higher escalating floor and CAP cores at 8 to halve the fork
    // memory (it's memory-bound, not core-bound). 200/400/512 G across attempts; 512 G is the
    // resourceLimits ceiling. Likely why Patient_1's NUMBAT_RUN never finished before.
    withName: NUMBAT_RUN {
        cpus   = 8
        memory = { 200.GB * task.attempt }
        time   = { 24.h   * task.attempt }
    }

    // RNA downstream stack runs from DDE_27's .sif (container = params.*_container, set above).
    // Load Apptainer so the engine is on PATH (beforeScript runs outside the container).
    withName: 'RNA_QC|RNA_NORMALIZE|RNA_FEATURE_SELECT|RNA_DIMRED|RNA_CLUSTER|RNA_ANNOTATE|RNA_INTEGRATE|RNA_PSEUDOTIME|RNA_VELOCITY|RNA_DE|RNA_COMPOSITION|PROT_QC|PROT_NORMALIZE|PROT_DOUBLET|PROT_DIMRED|PROT_BATCH_CORRECT|PROT_ANNOTATE' {
        beforeScript = 'module load Apptainer/latest'
    }

    // Bulk proteomics (DDE_31 port): Python stages from a conda env carrying pandas/scipy/sklearn/
    // scanpy/seaborn/inmoose (create `aml_proteomics` on the login node — see scratchpad Phase 15).
    // The single DESP step needs R + the DESP package: route it to an R conda env `desp_r`.
    withName: 'PROT_MS_PREP|PROT_MS_BATCH|PROT_MS_DE|PROT_MS_VIZ|PROT_MS_STAGE4|PROT_MS_ML|PROT_MS_PROPORTIONS|PROT_MS_DESP_VIZ' {
        container    = null
        beforeScript = 'module load Miniconda3/23.5.2-0; source activate aml_proteomics'
    }
    withName: PROT_MS_DESP {
        container    = null
        beforeScript = 'module load Miniconda3/23.5.2-0; source activate desp_r'
    }
}

// numbat.sif lacks `ps` (procps) and Nextflow's metric launcher hard-requires it
// (souporcell.sif + the DDE_27 RNA .sifs DO have ps). Disable the metric-collecting trace observers
// so .sif tasks don't need ps. Also launch with `-plugins nf-schema@2.7.2,nf-prov@1.7.0` (see
// jobs/run_controls.sh) so the co2footprint plugin doesn't force metric collection either.
//
// PRODUCTION FIX: bake `ps` into numbat.sif via containers/def/numbat_procps.def (one-off login-node
//   `apptainer build --fakeroot`), point numbat_container at the rebuilt image, then DELETE the four
//   `enabled = false` lines below so the execution report / timeline / trace / DAG render again —
//   provenance + carbon reporting is the Seqera-launchable selling point and is otherwise off here.
report   { enabled = false }
timeline { enabled = false }
trace    { enabled = false }
dag      { enabled = false }
