/*
 * Per-process publishDir contracts and ext.args.
 *
 * results/ layout (consolidated into thematic families):
 *   cellranger/                         Cell Ranger multi outputs
 *   callers/{numbat,copykat,souporcell,clonetracer}/   the variant callers + their figures
 *   annotation/{qc,reference_mapping}/  scanpy QC + reference mapping branch
 *   multimodal/{integration,lsc_scoring}/   per-patient master table, LSC scores, headline Sankeys
 *   rna/{core,integration,pseudotime,velocity,de,composition}/   DDE_27 RNA best-practices stack
 *   protein/{per_sample,integrated}/    ADT / surface-protein branch
 *   robustness/                         CopyKAT robustness sweep (separate track)
 *   pipeline_info/                      cohort summary + provenance/carbon/execution reports
 *
 * The default below gives any process without an explicit rule a publish dir under
 * <outdir>/<process_name_lowercase>/.
 */

process {
    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':').last().toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    // ── Cell Ranger ──
    withName: CELLRANGER_MULTI {
        // publish only the canonical '<sample>/outs/...'; skip versions + the flat
        // sample-named handles (<id>.bam etc.) that exist only for downstream staging.
        publishDir = [
            path: { "${params.outdir}/cellranger" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> (filename == 'versions.yml' || !filename.contains('/outs')) ? null : filename }
        ]
    }

    // ── Callers: Numbat (CNV) ──
    withName: NUMBAT_PILEUP {
        publishDir = [
            path: { "${params.outdir}/callers/numbat/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }
    withName: NUMBAT_RUN {
        // emits '<patient>/numbat_out' -> results/callers/numbat/<patient>/numbat_out
        publishDir = [
            path: { "${params.outdir}/callers/numbat" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    // ── Callers: CopyKAT (aneuploidy) ──
    withName: COPYKAT {
        publishDir = [
            path: { "${params.outdir}/callers/copykat/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }
    withName: PLOT_COPYKAT {
        publishDir = [
            path: { "${params.outdir}/callers/copykat/${meta.id}/figures" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    // ── Callers: souporcell (SNV) ──
    withName: SOUPORCELL_PREP {
        // intermediate merged BAM — not published by default (large); enable if needed
        publishDir = [ enabled: false ]
    }
    withName: SOUPORCELL {
        // emits '<patient>/k<K>' -> results/callers/souporcell/<patient>/k<K>
        publishDir = [
            path: { "${params.outdir}/callers/souporcell" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }
    withName: PLOT_SOUPORCELL {
        publishDir = [
            path: { "${params.outdir}/callers/souporcell/${meta.id}/figures" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    // ── Callers: CloneTracer (downstream clonal integration) ──
    withName: MTDNA_PILEUP {
        // per-sample mtDNA pileup — intermediate for CloneTracer; not published by default
        publishDir = [ enabled: false ]
    }
    withName: 'CLONETRACER_BUILD|CLONETRACER' {
        // <patient>.json + clone trees/posteriors -> results/callers/clonetracer/<patient>
        publishDir = [
            path: { "${params.outdir}/callers/clonetracer/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }
    withName: PLOT_CLONETRACER {
        publishDir = [
            path: { "${params.outdir}/callers/clonetracer/${meta.id}/figures" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    // ── Annotation branch (scanpy QC + reference mapping) ──
    withName: SCANPY_QC {
        publishDir = [
            path: { "${params.outdir}/annotation/qc/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }
    withName: REFERENCE_MAPPING {
        publishDir = [
            path: { "${params.outdir}/annotation/reference_mapping/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    // ── Multi-modal integration (per-patient master table + LSC + headline Sankeys) ──
    withName: 'LSC_SCORING' {
        publishDir = [
            path: { "${params.outdir}/multimodal/lsc_scoring/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }
    withName: 'PHASE0_INTEGRATION' {
        publishDir = [
            path: { "${params.outdir}/multimodal/integration/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }
    withName: 'HEADLINE_FIGURES' {
        publishDir = [
            path: { "${params.outdir}/multimodal/integration/${meta.id}/headline" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    // ── CopyKAT robustness sweep (separate analysis track) ──
    withName: COPYKAT_NORM_BARCODES {
        publishDir = [
            path: { "${params.outdir}/robustness/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }
    withName: COPYKAT_SWEEP {
        publishDir = [
            path: { "${params.outdir}/robustness/${meta.id}/sweep/${meta.combo.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    // ── RNA downstream best-practices stack (ported from DDE_27) ──
    withName: 'RNA_QC|RNA_NORMALIZE|RNA_FEATURE_SELECT|RNA_DIMRED|RNA_CLUSTER|RNA_ANNOTATE' {
        publishDir = [
            path: { "${params.outdir}/rna/core/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }
    withName: RNA_INTEGRATE {
        publishDir = [
            path: { "${params.outdir}/rna/integration" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }
    withName: RNA_PSEUDOTIME {
        publishDir = [
            path: { "${params.outdir}/rna/pseudotime/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }
    withName: RNA_VELOCITY {
        publishDir = [
            path: { "${params.outdir}/rna/velocity/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }
    withName: RNA_DE {
        // keyed by patient
        publishDir = [
            path: { "${params.outdir}/rna/de/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }
    withName: RNA_COMPOSITION {
        publishDir = [
            path: { "${params.outdir}/rna/composition" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    // ── Protein / ADT branch ──
    withName: 'PROT_QC|PROT_NORMALIZE|PROT_DOUBLET|PROT_DIMRED' {
        publishDir = [
            path: { "${params.outdir}/protein/per_sample/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }
    withName: 'PROT_BATCH_CORRECT|PROT_ANNOTATE' {
        publishDir = [
            path: { "${params.outdir}/protein/integrated" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    // ── Cohort reporting ──
    withName: COHORT_SUMMARY {
        publishDir = [
            path: { "${params.outdir}/pipeline_info" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }
}
