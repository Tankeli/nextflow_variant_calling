/*
 * Per-process publishDir contracts and ext.args.
 * Populated as modules land (Phases 2-4). The default below gives every process a
 * symlinked publish location under <outdir>/<process_name_lowercase>/.
 */

process {
    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':').last().toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    withName: NUMBAT_PILEUP {
        publishDir = [
            path: { "${params.outdir}/numbat_joint/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    withName: NUMBAT_RUN {
        // emits '<patient>/numbat_out' -> results/numbat_joint/<patient>/numbat_out
        publishDir = [
            path: { "${params.outdir}/numbat_joint" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    withName: SCANPY_QC {
        publishDir = [
            path: { "${params.outdir}/qc/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    withName: REFERENCE_MAPPING {
        publishDir = [
            path: { "${params.outdir}/reference_mapping/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    withName: COPYKAT {
        publishDir = [
            path: { "${params.outdir}/copykat/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    withName: PLOT_COPYKAT {
        publishDir = [
            path: { "${params.outdir}/copykat/${meta.id}/figures" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    withName: COPYKAT_NORM_BARCODES {
        publishDir = [
            path: { "${params.outdir}/copykat_robustness/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    withName: COPYKAT_SWEEP {
        publishDir = [
            path: { "${params.outdir}/copykat_robustness/${meta.id}/sweep/${meta.combo.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    withName: PLOT_SOUPORCELL {
        publishDir = [
            path: { "${params.outdir}/souporcell/${meta.id}/figures" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    withName: COHORT_SUMMARY {
        publishDir = [
            path: { "${params.outdir}/pipeline_info" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    withName: 'LSC_SCORING' {
        publishDir = [
            path: { "${params.outdir}/lsc_scoring/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    withName: 'PHASE0_INTEGRATION' {
        publishDir = [
            path: { "${params.outdir}/integration/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    withName: 'HEADLINE_FIGURES' {
        publishDir = [
            path: { "${params.outdir}/integration/${meta.id}/headline" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    withName: SOUPORCELL_PREP {
        // intermediate merged BAM — not published by default (large); enable if needed
        publishDir = [ enabled: false ]
    }

    withName: MTDNA_PILEUP {
        // per-sample mtDNA pileup — intermediate for CloneTracer; not published by default
        publishDir = [ enabled: false ]
    }

    withName: 'CLONETRACER_BUILD|CLONETRACER' {
        // <patient>.json + clone trees/posteriors -> results/clonetracer/<patient>
        publishDir = [
            path: { "${params.outdir}/clonetracer/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    withName: PLOT_CLONETRACER {
        publishDir = [
            path: { "${params.outdir}/clonetracer/${meta.id}/figures" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    withName: SOUPORCELL {
        // emits '<patient>/k<K>' -> results/souporcell/<patient>/k<K>
        publishDir = [
            path: { "${params.outdir}/souporcell" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    // ── RNA downstream best-practices stack (ported from DDE_27) ──
    // RNA core (per sample) -> results/rna/<sample>
    withName: 'RNA_QC|RNA_NORMALIZE|RNA_FEATURE_SELECT|RNA_DIMRED|RNA_CLUSTER|RNA_ANNOTATE' {
        publishDir = [
            path: { "${params.outdir}/rna/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }
    withName: RNA_INTEGRATE {
        publishDir = [
            path: { "${params.outdir}/rna_integration" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }
    withName: RNA_PSEUDOTIME {
        publishDir = [
            path: { "${params.outdir}/rna_pseudotime/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }
    withName: RNA_VELOCITY {
        publishDir = [
            path: { "${params.outdir}/rna_velocity/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }
    withName: RNA_DE {
        // keyed by patient
        publishDir = [
            path: { "${params.outdir}/de/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }
    withName: RNA_COMPOSITION {
        publishDir = [
            path: { "${params.outdir}/composition" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }
    // Protein / ADT (per sample) -> results/protein/<sample>; batch-correct + annotate cohort
    withName: 'PROT_QC|PROT_NORMALIZE|PROT_DOUBLET|PROT_DIMRED' {
        publishDir = [
            path: { "${params.outdir}/protein/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }
    withName: 'PROT_BATCH_CORRECT|PROT_ANNOTATE' {
        publishDir = [
            path: { "${params.outdir}/protein_integrated" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    withName: CELLRANGER_MULTI {
        // publish only the canonical '<sample>/outs/...'; skip versions + the flat
        // sample-named handles (<id>.bam etc.) that exist only for downstream staging.
        publishDir = [
            path: { "${params.outdir}/cellranger" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> (filename == 'versions.yml' || !filename.contains('/outs')) ? null : filename }
        ]
    }
}
